{
  "type": "module",
  "scripts": {
    "test": "node --test __tests__/*.test.js",
    "eval:chat": "node scripts/mcp-chat-eval.mjs",
    "eval:chat:list": "node scripts/mcp-chat-eval.mjs --list --all",
    "eval:chat:all": "node scripts/mcp-chat-eval.mjs --all",
    "eval:chat:tool-loop": "node scripts/mcp-chat-eval.mjs --surface=tool-loop",
    "eval:chat:full-surface": "node scripts/mcp-chat-eval.mjs --surface=tool-loop --tool-mode=full --no-final --max-output=350",
    "eval:chat:groq": "node scripts/mcp-chat-eval.mjs --provider=groq"
  }
}
